# Nova-Home Environment Variables
# Fill these in and rename to .env

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_token_here

# Channel IDs for different brain functions
MAIN_CHANNEL_ID=your_main_channel_id_here
DIARY_CHANNEL_ID=your_diary_channel_id_here
DREAMS_CHANNEL_ID=your_dreams_channel_id_here

# AI Provider Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Horde Key (for !draw command)
# Use "0000000000" for anonymous (slower) or get a key at aihorde.net
HORDE_API_KEY=0000000000
